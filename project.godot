; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="simplyRemadeNuxi"
config/version="0.1.5"
run/main_scene="uid://f4a6hf0g12j2"
config/use_custom_user_dir=true
config/custom_user_dir_name="mineImatorNuxi"
config/auto_accept_quit=false
config/features=PackedStringArray("4.7", "C#", "Forward Plus")
run/max_fps=60
run/low_processor_mode=true
boot_splash/show_image=false
config/icon="uid://bldbm3le7r54m"
config/windows_native_icon="res://assets/img/appIcon01.ico"

[autoload]

SelectionManager="*uid://cagt7pjdbi66f"
VoxelSettings="*uid://p50e41mp6pj5"

[debug]

file_logging/log_path="user://logs/nuxi.log"

[debug_draw_3d]

settings/addon_root_folder="res://addons/debug_draw_3d"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/subwindows/embed_subwindows=false
window/stretch/mode="viewport"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="simplyRemadeNuxi"

[editor]

naming/default_signal_callback_name="On{NodeName}{SignalName}"
naming/default_signal_callback_to_self_name="On{SignalName}"
naming/scene_name_casing=1
naming/script_name_casing=1

[editor_plugins]

enabled=PackedStringArray("res://addons/Gizmo3DSharp/plugin.cfg", "res://addons/SunshineClouds2/plugin.cfg", "res://addons/csharp_gdextension_bindgen/plugin.cfg", "res://addons/dockable_container/plugin.cfg", "res://addons/plugin_refresher/plugin.cfg", "res://addons/shader_library/plugin.cfg")

[physics]

2d/physics_engine="Dummy"
3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
textures/vram_compression/import_s3tc_bptc=true
textures/vram_compression/import_etc2_astc=true
global_illumination/gi/use_half_resolution=true
scaling_3d/mode=1
